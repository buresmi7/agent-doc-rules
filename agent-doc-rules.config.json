{
  "docs": {
    "include": [
      "*.md",
      "docs/**/*.md",
      "packages/**/*.md",
      "e2e/**/*.md"
    ],
    "exclude": [
      "node_modules/**",
      ".git/**",
      "dist/**",
      "coverage/**",
      ".tmp/**",
      "repos/**",
      "worktrees/**"
    ],
    "links": {
      "exclude": [
        "node_modules/**",
        ".git/**",
        "dist/**",
        "coverage/**",
        ".tmp/**",
        "repos/**",
        "worktrees/**",
        "e2e/**/snapshot*/**"
      ],
      "skip": [
        "^https://"
      ]
    },
    "wording": {
      "writeGood": {
        "passive": false,
        "illusion": false,
        "weasel": false,
        "adverb": false,
        "tooWordy": false,
        "eprime": false,
        "fail": false
      },
      "exclude": [
        "node_modules/**",
        ".git/**",
        "dist/**",
        "coverage/**",
        ".tmp/**",
        "repos/**",
        "worktrees/**",
        "e2e/**/snapshot/**",
        "e2e/plain-english-doc-review/**",
        "packages/agent-doc-rules-skill/references/writing-style.md"
      ],
      "forbiddenTerms": [],
      "allow": []
    },
    "style": {
      "exclude": [
        "node_modules/**",
        ".git/**",
        "dist/**",
        "coverage/**",
        ".tmp/**",
        "repos/**",
        "worktrees/**",
        "CHANGELOG.md",
        "e2e/**"
      ],
      "includeReferences": false,
      "maxUnits": 80,
      "model": "gpt-5.5",
      "reasoningEffort": "low"
    },
    "duplicates": {
      "exclude": [
        "node_modules/**",
        ".git/**",
        "dist/**",
        "coverage/**",
        ".tmp/**",
        "repos/**",
        "worktrees/**",
        "e2e/**/snapshot*/**"
      ],
      "includeReferences": false,
      "includeSameFile": false,
      "warnScore": 0.78,
      "failScore": 0.92,
      "minWords": 6,
      "minChars": 40,
      "maxCandidates": 25,
      "model": "gpt-5.5",
      "reasoningEffort": "low"
    }
  }
}
